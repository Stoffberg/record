{
  "name": "record",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @record/desktop tauri dev",
    "build": "pnpm --filter @record/desktop tauri build",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "format": "biome format --write",
    "typecheck": "pnpm --filter @record/desktop exec tsc -b",
    "test": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "test:rust": "cargo test --manifest-path apps/desktop/src-tauri/Cargo.toml",
    "clippy": "cargo clippy --manifest-path apps/desktop/src-tauri/Cargo.toml -- -D warnings",
    "fmt:rust": "cargo fmt --manifest-path apps/desktop/src-tauri/Cargo.toml --check",
    "check": "pnpm lint && pnpm typecheck && pnpm fmt:rust && pnpm clippy && pnpm test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.6"
  }
}
